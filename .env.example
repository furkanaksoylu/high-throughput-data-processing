NODE_ENV=development
PORT=3000

WORKER_METRICS_PORT=9091

DB_HOST=postgres
DB_PORT=5432
DB_USER=app
DB_PASS=app
DB_NAME=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
DB_POOL_MAX=10
DATABASE_URL=postgresql://app:app@postgres:5432/app

REDIS_HOST=redis
REDIS_PORT=6379

STORAGE_DIR=/data

BULK_QUEUE_NAME=bulk
BULK_WORKER_CONCURRENCY=2
JOB_RECOVERY_EVERY_MS=30000
STALE_JOB_TIMEOUT_MS=1800000

JOB_PROGRESS_EVERY=5000
IMPORT_FLUSH_SIZE=1000
IMPORT_MAX_FILE_BYTES=1073741824
IMPORT_FETCH_TIMEOUT_MS=30000
EXPORT_FETCH_BATCH_SIZE=1000

METRICS_ENABLED=true

DOCS_ENABLED=true
AUTH_RATE_LIMIT_MAX=20

SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PASSWORD=ChangeMeSuperAdmin123!

JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=12h

SALT_ROUNDS=12

GRAFANA_ADMIN_PASSWORD=admin