{
  "name": "high-throughput-data-processing",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "author": "Furkan Aksoylu",
  "scripts": {
    "dev": "tsx watch src/main/api.ts",
    "build": "rm -rf dist && DATABASE_URL=${DATABASE_URL:-postgresql://app:app@localhost:5432/app} prisma generate --schema prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "node dist/main/api.js",
    "worker": "node dist/interfaces/worker/index.js",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://app:app@localhost:5432/app} prisma generate --schema prisma/schema.prisma",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest run tests/integration",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@scalar/fastify-api-reference": "^1.44.24",
    "@types/pg": "^8.16.0",
    "@types/stream-json": "^1.7.8",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.12.0",
    "dotenv": "^17.3.1",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "pg-copy-streams": "^6.0.6",
    "pino": "^9.3.1",
    "prisma": "^7.4.1",
    "prom-client": "^15.1.3",
    "split2": "^4.2.0",
    "stream-chain": "^3.4.0",
    "stream-json": "^1.9.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/split2": "^4.2.3",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
